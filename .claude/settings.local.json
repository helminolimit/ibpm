{
  "permissions": {
    "allow": [
      "Bash(php artisan *)",
      "Bash(vendor/bin/pint --dirty --format agent)",
      "mcp__laravel-boost__application-info",
      "Bash(xargs grep *)",
      "Bash(grep *)",
      "Bash(mcp__laravel-boost__database-schema --summary)",
      "Bash(vendor/bin/pint *)",
      "Bash(git -C /c/laragon/www/ibpm log --oneline --all -20)",
      "mcp__laravel-boost__database-connections"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "laravel-boost"
  ],
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 2
  }
}
